# Backend environment template — copy to backend/.env (gitignored)

# Database
DATABASE_URL=postgresql+asyncpg://wealth_user:dev_password@localhost:5432/wealthflightplan

# Redis (token blacklist + rate limiting)
REDIS_URL=redis://localhost:6379/0

# JWT (RS256)
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=2592000
JWT_VERIFICATION_TOKEN_EXPIRE_SECONDS=86400
JWT_RESET_TOKEN_EXPIRE_SECONDS=3600
JWT_ISSUER=wealthflightplan

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (SendGrid). If SENDGRID_API_KEY is empty, emails are logged to stdout.
SENDGRID_API_KEY=
EMAIL_FROM=noreply@wealthflightplan.local
EMAIL_FROM_NAME=Wealth FlightPlan

# HIBP (pwned passwords). Public k-anonymity range API needs no key.
HIBP_ENABLED=true
HIBP_TIMEOUT_SECONDS=2

# Rate limits (slowapi strings)
RATE_LIMIT_REGISTER=5/hour
RATE_LIMIT_LOGIN=10/hour
RATE_LIMIT_PASSWORD_RESET=3/hour
RATE_LIMIT_AUTHED=100/minute
