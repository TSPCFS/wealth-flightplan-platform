# Frontend env (Vite reads VITE_* vars at build time)
#
# Local development:
#   cp .env.example .env
#   # default points at the Docker backend on :8000; for the override
#   # port-remap, use http://localhost:58000
#
# Vercel production:
#   Set VITE_API_URL in the project's Environment Variables to your Railway
#   backend URL (e.g. https://wfp-api.up.railway.app).

VITE_API_URL=http://localhost:8000
