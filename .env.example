# ============================================================
# Wealth FlightPlan — Environment Variables Template
# Copy this to `.env` (gitignored) and fill in real values.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://wealth_user:dev_password@localhost:5432/wealthflightplan

# --- Redis (token blacklist, rate limits, cache) ---
REDIS_URL=redis://localhost:6379/0

# --- JWT (RS256) ---
# Generate locally with:
#   openssl genrsa -out keys/jwt_private.pem 2048
#   openssl rsa -in keys/jwt_private.pem -pubout -out keys/jwt_public.pem
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=2592000
JWT_ISSUER=wealthflightplan

# --- App ---
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# --- SendGrid (email verification, password reset) ---
SENDGRID_API_KEY=
EMAIL_FROM=noreply@wealthflightplan.local

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8000
